{
  "name": "brandbase",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup": "cd backend && pip install -r requirements.txt",
    "dev:backend": "cd backend && uvicorn main:app --reload --port 8001",
    "dev:frontend": "cd web && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "cd web && npm run build",
    "deploy:backend": "echo 'Connect Render to your GitHub repo'",
    "deploy:frontend": "echo 'Connect Vercel to web/ folder'"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}