{
  "name": "brandbase",
  "version": "1.0.0",
  "private": true,
  "description": "CRM for service businesses - https://brandbase.app",
  "scripts": {
    "setup": "cd backend && pip install -r requirements.txt",
    "dev:backend": "cd backend && uvicorn main:app --reload --port 8001",
    "dev:frontend": "cd web && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "cd web && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "next": "14.1.0"
  }
}